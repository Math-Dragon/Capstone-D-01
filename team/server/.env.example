# AI Learning Plan — Environment Configuration
# Salin file ini menjadi .env dan isi dengan nilai Anda.
# JANGAN commit file .env ke repository.

DATABASE_URL=postgres://user:pass@localhost:5432/planner
JWT_SECRET=changeme_minimal_32_karakter_random
JWT_REFRESH_SECRET=changeme_juga_minimal_32_karakter_random

# LLM Provider: "mock", "gemini", or "ollama"
#   mock — mengembalikan template tasks statis, cocok untuk development
#   gemini — menggunakan Google Gemini API, membutuhkan GEMINI_API_KEY valid
#   ollama — menggunakan Ollama lokal, membutuhkan OLLAMA_BASE_URL
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Local LLM (fallback when LLM_PROVIDER=gemini, or primary when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# OpenRouter (legacy — no longer used as fallback, kept for reference)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

FIREBASE_SERVICE_ACCOUNT='{
  "type": "service_account",
  "project_id": "your_project_id",
  "private_key_id": "your_private_key_id",
  "private_key": "PASTE_ESCAPED_FIREBASE_PRIVATE_KEY_HERE",
  "client_email": "firebase-adminsdk@your_project.iam.gserviceaccount.com",
  "client_id": "your_client_id",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk@your_project.iam.gserviceaccount.com",
  "universe_domain": "googleapis.com"
}'

REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Production example
# NODE_ENV=production
# ALLOWED_ORIGINS=https://your-frontend.vercel.app
# REDIS_URL=redis://default:password@your-render-redis:6379
