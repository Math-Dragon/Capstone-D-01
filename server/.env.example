# AI Learning Plan — Environment Configuration
# Salin file ini menjadi .env dan isi dengan nilai Anda.
# JANGAN commit file .env ke repository.

DATABASE_URL=postgres://user:pass@localhost:5432/planner
JWT_SECRET=changeme_minimal_32_karakter_random
JWT_REFRESH_SECRET=changeme_juga_minimal_32_karakter_random

# LLM Provider: "mock" (tanpa API key) atau "gemini" (real AI)
#   mock — mengembalikan template tasks statis, cocok untuk development
#   gemini — menggunakan Google Gemini API, membutuhkan GEMINI_API_KEY valid
LLM_PROVIDER=mock
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-1.5-flash    # opsional, default: gemini-1.5-flash
#                                  # alternatif: gemini-2.0-flash, gemini-1.5-pro
# Saat mengganti LLM_PROVIDER=gemini:
#   1. Isi GEMINI_API_KEY dengan API key dari Google AI Studio (https://aistudio.google.com/apikey)
#   2. Opsional: ubah GEMINI_MODEL (default: gemini-1.5-flash)
#   3. Server akan memvalidasi koneksi Gemini saat startup

REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
